# Build output
/target/

# Uncompressed vendor sources — always extract from vendor.tar.xz; never commit the directory
/vendor/

# .cargo/config.toml is written by CI (Jenkinsfile) and local airgap scripts; not committed
# so that online dev builds continue to use crates.io by default.
/.cargo/config.toml

# Logs and temp files
*.log
*.tmp
*.bak

# OS artefacts
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/

# Secrets / local env
.env
ci/jenkins/.env

# Local test output (not for commit)
out/
out.7z
tmp-sloc/

# Loose report artefacts from local runs
result.json
result.html
result.pdf

# Clippy machine-readable output (generated by CI/SonarQube scripts)
clippy.json
clippy-sonar.json
clippy.stderr

# Coverage / profiling (cargo-llvm-cov, grcov, cargo-flamegraph)
*.profraw
*.profdata
lcov.info
flamegraph.svg
perf.data
perf.data.old

# dist/ — all compiled binaries and archives (released as GitHub release assets)
/dist/

# Generated report artefacts under tests/fixtures/
tests/fixtures/**/sloc/

# Transferable bundle archives created by `make bundle`
/oxide-sloc-bundle*.7z
/oxide-sloc-bundle*.tar.gz

# Claude Code (project-local AI context — not for commit)
CLAUDE.md
.claude
