# Set to your Jenkins host. LAN/remote URLs are fine. Strip any trailing slash.
# 'export' prefixes let bash scripts (child processes) inherit these.
export JENKINS_URL=http://localhost:8080
export JENKINS_USER=admin
export JENKINS_TOKEN=
# Use oxide-sloc-manual if oxide-sloc already exists in this Jenkins instance.
export JOB_NAME=oxide-sloc

# The git repo Jenkins fetches the Jenkinsfile from. Override for forks/mirrors.
export REPO_URL=https://github.com/oxide-sloc/oxide-sloc.git

# Bitbucket integration (optional — only needed if using Bitbucket as SCM)
export BITBUCKET_URL=https://bitbucket.example.com
export BITBUCKET_PROJECT=OXIDE
export BITBUCKET_REPO=oxide-sloc
