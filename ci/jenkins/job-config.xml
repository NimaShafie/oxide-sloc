<?xml version='1.1' encoding='UTF-8'?>
<!--
  Importable Jenkins Pipeline-from-SCM job definition for oxide-sloc.

  Bootstrap in one command (requires curl, a Jenkins crumb, and admin credentials):

    JENKINS_URL=http://localhost:8080
    JENKINS_USER=admin
    JENKINS_PASS=<your-password-or-api-token>

    # 1. Obtain a CSRF crumb
    CRUMB=$(curl -su "${JENKINS_USER}:${JENKINS_PASS}" \
        "${JENKINS_URL}/crumbIssuer/api/xml?xpath=concat(//crumbRequestField,\":\",//crumb)")

    # 2. Create the job
    curl -su "${JENKINS_USER}:${JENKINS_PASS}" \
        -H "${CRUMB}" \
        -H "Content-Type: application/xml" \
        --data-binary @ci/jenkins/job-config.xml \
        "${JENKINS_URL}/createItem?name=oxide-sloc"

  After the job is created, trigger one build with no parameters so Jenkins
  discovers the parameters{} block in the Jenkinsfile — the full "Build with
  Parameters" form appears from build #2 onward.

  For Job DSL users, see ci/jenkins/seed-job.groovy instead.
-->
<flow-definition plugin="workflow-job">
  <description>oxide-sloc — SLOC analysis pipeline. Scans source repositories and produces HTML, JSON, and PDF reports with build-over-build trend data.</description>
  <keepDependencies>false</keepDependencies>
  <properties>
    <jenkins.model.BuildDiscarderProperty>
      <strategy class="hudson.tasks.LogRotator">
        <daysToKeep>-1</daysToKeep>
        <numToKeep>25</numToKeep>
        <artifactDaysToKeep>-1</artifactDaysToKeep>
        <artifactNumToKeep>10</artifactNumToKeep>
      </strategy>
    </jenkins.model.BuildDiscarderProperty>
  </properties>
  <definition class="org.jenkinsci.plugins.workflow.cps.CpsScmFlowDefinition" plugin="workflow-cps">
    <scm class="hudson.plugins.git.GitSCM" plugin="git">
      <configVersion>2</configVersion>
      <userRemoteConfigs>
        <hudson.plugins.git.UserRemoteConfig>
          <url>https://github.com/oxide-sloc/oxide-sloc.git</url>
        </hudson.plugins.git.UserRemoteConfig>
      </userRemoteConfigs>
      <branches>
        <hudson.plugins.git.BranchSpec>
          <name>*/main</name>
        </hudson.plugins.git.BranchSpec>
      </branches>
      <doGenerateSubmoduleConfigurations>false</doGenerateSubmoduleConfigurations>
      <submoduleCfg class="empty-list"/>
      <extensions/>
    </scm>
    <scriptPath>Jenkinsfile</scriptPath>
    <lightweight>true</lightweight>
  </definition>
  <disabled>false</disabled>
</flow-definition>
