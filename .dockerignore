target/
out/
out.7z
tmp-sloc/
*.log
*.tmp
.git/
.vscode/
.idea/
# Uncompressed vendor tree — the Dockerfile verifies vendor.tar.xz with sha256sum
# and extracts it at build time, so the pre-expanded directory is never needed.
vendor/
# rust-toolchain-bundle is only used by the Jenkins offline agent image.
rust-toolchain-bundle.tar.xz
rust-toolchain-bundle.tar.xz.sha256
# dist/ and deploy/ are runtime-deployment artifacts, not needed to compile.
dist/
deploy/
# Local editor / IDE state.
.claude/
images/
examples/
