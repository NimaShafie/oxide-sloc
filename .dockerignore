target/
out/
tmp-sloc/
*.log
*.tmp
.git/
.vscode/
.idea/
# Uncompressed vendor tree — Docker always extracts from vendor.tar.xz instead,
# so the directory must be excluded to prevent COPY from shadowing the archive.
vendor/
# Large binary artifacts not needed at image build time.
# rust-toolchain.toml is NOT excluded — Dockerfile.agent COPYs it.
vendor.tar.xz
vendor.tar.xz.sha256
rust-toolchain-bundle.tar.xz
rust-toolchain-bundle.tar.xz.sha256
crates/
tests/
docs/
scripts/
Cargo.lock
