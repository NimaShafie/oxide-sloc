# Jenkins CI agent for oxide-sloc
#
# Extends jenkins/jenkins:lts with everything the Jenkinsfile needs:
#   - python3          Extract plot data stage (summary.csv / per_language.csv)
#   - build-essential  Native libs required by some Rust crates
#   - pkg-config       Required by openssl-sys, wayland-sys, gtk-sys, etc.
#   - libssl-dev       TLS support for Rust HTTP clients
#   - libwayland-dev   Required by `rfd` crate (activated by --all-features)
#   - libgtk-3-dev     Required by `rfd` crate (activated by --all-features)
#   - libxdo-dev       Required by `rfd` crate (activated by --all-features)
#   - xz-utils         tar -xJf decompression of vendor.tar.xz
#   - curl             rustup installer (image build only) + web UI health check
#
# ── Fully offline pipeline runs ────────────────────────────────────────────────
# The Rust toolchain (rustc, cargo, rustfmt, clippy) is baked into the image at
# /opt/rust-toolchain during docker build — no internet access is needed during
# the pipeline run itself.  On first use the Jenkinsfile Setup stage copies the
# toolchain into the persistent /var/jenkins_home/.rust-cache volume; every
# subsequent build uses the cache directly.
#
# Cargo crate dependencies are covered by vendor.tar.xz committed to git —
# a plain `git clone` + extract is sufficient; crates.io is never contacted.
#
# Build and use:
#   docker build -t jenkins-oxide-sloc:latest -f ci/jenkins/Dockerfile.agent .
#
# In docker-compose.yml for the Jenkins service, replace:
#   image: jenkins/jenkins:lts
# with:
#   build:
#     context: .
#     dockerfile: ci/jenkins/Dockerfile.agent
#   image: jenkins-oxide-sloc:latest
#
# ── Updating the toolchain version ─────────────────────────────────────────────
# The toolchain version is read from rust-toolchain.toml at image build time.
# After bumping the channel value, rebuild the image and redeploy the container.

FROM jenkins/jenkins:lts-jdk21

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-minimal \
    build-essential \
    pkg-config \
    libssl-dev \
    libwayland-dev \
    libgtk-3-dev \
    libxdo-dev \
    curl \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

# Install the pinned Rust toolchain at image build time so all pipeline runs are
# fully offline — no sh.rustup.rs request during cargo build, fmt, or clippy.
# The Jenkinsfile Setup stage copies cargo/ and rustup/ from /opt/rust-toolchain
# into the persistent /var/jenkins_home/.rust-cache volume on first use; every
# subsequent build hits the cache directly and skips this copy entirely.
COPY rust-toolchain.toml /tmp/rust-toolchain.toml
RUN set -eux; \
    TOOLCHAIN=$(grep '^channel' /tmp/rust-toolchain.toml | cut -d'"' -f2); \
    export CARGO_HOME=/opt/rust-toolchain/cargo \
           RUSTUP_HOME=/opt/rust-toolchain/rustup; \
    mkdir -p "$CARGO_HOME" "$RUSTUP_HOME"; \
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y \
              --default-toolchain "$TOOLCHAIN" \
              --component rustfmt clippy \
              --no-modify-path; \
    rm /tmp/rust-toolchain.toml; \
    chmod -R a+rX /opt/rust-toolchain

# Pre-create the persistent Rust+vendor cache directory so the Jenkins user can
# write to it without requiring root on first use.
RUN mkdir -p /var/jenkins_home/.rust-cache && \
    chown -R jenkins:jenkins /var/jenkins_home/.rust-cache

USER jenkins
