#!/usr/bin/env bash
# Pre-commit hook: warns when Cargo.toml or Cargo.lock is staged without a
# corresponding update to vendor.tar.xz.
#
# This is a warning-only hook — it never blocks the commit.
# The vendor-sync job in ci.yml will fail the build if there is a real mismatch.
#
# Install: git config core.hooksPath .githooks
# (or run: bash scripts/install-hooks.sh)

CARGO_CHANGED=$(git diff --cached --name-only 2>/dev/null | grep -E 'Cargo\.(toml|lock)$' || true)
VENDOR_CHANGED=$(git diff --cached --name-only 2>/dev/null | grep -E 'vendor\.tar\.xz(\.sha256)?$' || true)

if [ -n "$CARGO_CHANGED" ] && [ -z "$VENDOR_CHANGED" ]; then
    echo ""
    echo "  ┌─────────────────────────────────────────────────────────────────┐"
    echo "  │  WARNING: Cargo.toml/Cargo.lock changed — vendor.tar.xz not    │"
    echo "  │  If you added, removed, or updated a dependency, run:           │"
    echo "  │    bash scripts/update-vendor.sh                                │"
    echo "  │    git add vendor.tar.xz vendor.tar.xz.sha256                  │"
    echo "  │  Version-only bumps (no dep changes) can ignore this warning.  │"
    echo "  │  CI will fail if vendor.tar.xz is actually out of sync.         │"
    echo "  └─────────────────────────────────────────────────────────────────┘"
    echo ""
fi

exit 0
