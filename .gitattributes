# Normalize all text files to LF on commit (no CRLF in the repo)
* text=auto eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.wasm binary
*.o binary
*.a binary
*.fst binary
*.dfa binary
*.der binary

# Vendor text sources — cargo checksums are computed on LF bytes.
# Do NOT add a catch-all vendor/** text rule — it overrides the binary
# declarations above and corrupts object/archive/FST files during checkout.
vendor/**/*.rs   text eol=lf
vendor/**/*.toml text eol=lf
vendor/**/*.json text eol=lf

# Static assets bundled into the binary
crates/sloc-web/static/*.js  text eol=lf
