/vendor.tar.xz
/vendor.tar.xz.sha256
/.cargo/config.toml

# Logs and temp files
*.log
*.tmp
*.bak

# OS artefacts
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/

# Secrets / local env
.env
ci/jenkins/.env

# Local test output (not for commit)
out/
out.7z
tmp-sloc/

# Loose report artefacts from local runs
result.json
result.html
result.pdf

# Coverage / profiling (cargo-llvm-cov, grcov, cargo-flamegraph)
*.profraw
*.profdata
lcov.info
flamegraph.svg
perf.data
perf.data.old

# dist/ — all compiled binaries and archives (released as GitHub release assets)
/dist/

